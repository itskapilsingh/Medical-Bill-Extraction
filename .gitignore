# Python-generated files
__pycache__
*.py[oc]
build/
dist/
wheels/
*.egg-info

data

# Virtual environments
.venv
.venv-test
venv/

# Environment variables
.env
.env.local
.env.*.local

# Node / Next.js (for the web/ frontend you add)
node_modules/
.next/
out/
*.tsbuildinfo

# Logs
.logs/
*.log

# Uploaded PDFs on the shared volume (runtime data, not source)
backend/pdfs/*
!backend/pdfs/.gitkeep

# Local/runtime output that may be derived from PHI (eval predictions, test
# runner artifacts) — must never be tracked or swept into a submission.
tmp/
test-results/
predictions/

# Packaged exports
*.zip
