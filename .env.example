# OpenAI
OPENAI_API_KEY=your_key_here

# Postgres (admin / migration role — owns the schema, may bypass RLS)
POSTGRES_USER=billing
POSTGRES_PASSWORD=billing
POSTGRES_DB=billing
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_CONNECTION_STRING=postgresql+asyncpg://billing:billing@postgres:5432/billing

# Application DB role (RLS-ENFORCED)
# The API and worker must connect to Postgres as a role that is SUBJECT TO RLS —
# NOT the table owner and NOT a BYPASSRLS/superuser role. Create this role in a
# migration, grant it only what it needs, and point the app at it here. The admin
# connection string above is for migrations only.
APP_DB_PASSWORD=billing_app
APP_DB_CONNECTION_STRING=postgresql+asyncpg://billing_app:billing_app@postgres:5432/billing

# Auth DB role (Better Auth only; no jobs privileges)
AUTH_DB_PASSWORD=billing_auth
AUTH_DATABASE_URL=postgresql://billing_auth:billing_auth@postgres:5432/billing

# App
PDF_MOUNT_PATH=/app/pdfs
LOG_LEVEL=INFO
ENVIRONMENT=development
WORKER_POLL_INTERVAL_SECONDS=5
MAX_UPLOAD_BYTES=26214400
MAX_UPLOAD_REQUEST_BYTES=27262976
PDF_MAX_PAGES=400
PDF_PARSE_TIMEOUT_SECONDS=60
EXTRACTION_TIMEOUT_SECONDS=180

# Model cost assumptions (USD per 1M tokens). Override when provider pricing changes.
EXTRACTION_MODEL=gpt-5.4-mini
PDF_FILE_EXTRACTION_MODEL=gpt-5.4-mini
LLM_PRICING_EFFECTIVE_DATE=2026-06-24
LLM_PRICE_GPT_5_4_INPUT_PER_1M=1.25
LLM_PRICE_GPT_5_4_CACHED_INPUT_PER_1M=0.125
LLM_PRICE_GPT_5_4_OUTPUT_PER_1M=10.0
LLM_PRICE_GPT_5_4_MINI_INPUT_PER_1M=0.25
LLM_PRICE_GPT_5_4_MINI_CACHED_INPUT_PER_1M=0.025
LLM_PRICE_GPT_5_4_MINI_OUTPUT_PER_1M=2.0
LLM_PRICE_GPT_5_4_NANO_INPUT_PER_1M=0.05
LLM_PRICE_GPT_5_4_NANO_CACHED_INPUT_PER_1M=0.005
LLM_PRICE_GPT_5_4_NANO_OUTPUT_PER_1M=0.40

# Comma-separated IPs of trusted reverse proxies. X-Forwarded-For is honored only
# when the request's immediate peer is listed here; otherwise the real TCP peer is
# used so a direct client can't spoof its source IP. Empty by default (the API is
# exposed directly in this compose setup). Set this if you put a proxy in front.
TRUSTED_PROXIES=

# Auth (Better Auth, served from the Next.js app)
# Works as-is for local runs. Generate your own for anything real:
#   openssl rand -hex 32
BETTER_AUTH_SECRET=dev_only_better_auth_secret_0123456789abcdef0123456789abcdef
BETTER_AUTH_URL=http://localhost:3000

# Frontend (Next.js)
# Server-to-server URL the Next.js BFF uses to reach the API over the compose
# network (also set in docker-compose.yml). To run the web app outside Docker,
# point this at http://localhost:8000.
API_INTERNAL_URL=http://api:8000
# Origins Better Auth accepts for CSRF/Origin checks (comma-separated).
# Only the web origin — the browser never calls the API directly.
TRUSTED_ORIGINS=http://localhost:3000

# Optional fallback for local non-Docker development only. Production web startup
# refuses to use DATABASE_URL for auth; use AUTH_DATABASE_URL above instead.
DATABASE_URL=postgresql://billing:billing@postgres:5432/billing
